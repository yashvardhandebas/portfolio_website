{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "create-react-app",
      "installCommand": "npm install --legacy-peer-deps",
      "buildCommand": "npm run build",
      "outputDirectory": "build"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
